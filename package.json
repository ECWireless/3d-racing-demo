{
  "name": "3d-racing-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx server/index.ts",
    "dev:all": "concurrently \"pnpm dev --host 0.0.0.0\" \"pnpm dev:api\"",
